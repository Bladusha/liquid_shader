      m_Calls: []
  m_text: "\u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u0431\u043B\u043E\u043A\u0430 \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445
    \u043C\u0435\u0440: \r\n- \u0432\u043D\u0430\u0447\u0430\u043B\u0435 \u043F\u0440\u0438\u0442\u0438\u0440\u0430\u044E\u0442
    \u043C\u0435\u0440\u044B \u043C\u0430\u043B\u044B\u0445 \u0440\u0430\u0437\u043C\u0435\u0440\u043E\u0432;
    \r\n- \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0439 \u0438\u0437 \u043D\u0438\u0445
    \u0431\u043B\u043E\u043A \u043F\u0440\u0438\u0442\u0438\u0440\u0430\u044E\u0442
    \u043A \u043C\u0435\u0440\u0435 \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E
    \u0440\u0430\u0437\u043C\u0435\u0440\u0430 \u0438 \u0437\u0430\u0442\u0435\u043C
    \u0443\u0436\u0435 \u043A \u043C\u0435\u0440\u0435 \u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E
    \u0440\u0430\u0437\u043C\u0435\u0440\u0430.\r"
