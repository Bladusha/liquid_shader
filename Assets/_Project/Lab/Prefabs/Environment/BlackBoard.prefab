  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041D\u0430\u0438\u0431\u043E\u043B\u044C\u0448\u0435\u0435 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435
    \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u0438 \u0444\u043E\u0440\u043C\u044B
    \u0434\u0435\u0442\u0430\u043B\u0435\u0439:\r\n\u041E\u0442\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u0435
    \u043E\u0442 \u043E\u043A\u0440\u0443\u0433\u043B\u043E\u0441\u0442\u0438 \u2013
    \u044D\u0442\u043E \u043D\u0430\u0438\u0431\u043E\u043B\u044C\u0448\u0435\u0435
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u0394 \u043E\u0442
    \u0442\u043E\u0447\u0435\u043A \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0438\u043B\u044F \u0434\u043E \u043F\u0440\u0438\u043B\u0435\u0433\u0430\u044E\u0449\u0435\u0439
    \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438. \u0427\u0430\u0441\u0442\u043D\u044B\u043C\u0438
    \u0432\u0438\u0434\u0430\u043C\u0438 \u043E\u0442\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u044F
    \u043E\u0442 \u043E\u043A\u0440\u0443\u0433\u043B\u043E\u0441\u0442\u0438 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043E\u0432\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0438 \u043E\u0433\u0440\u0430\u043D\u043A\u0430:\n\u041E\u0432\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u2013 \u043E\u0442\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u0435 \u043E\u0442
    \u043A\u0440\u0443\u0433\u043B\u043E\u0441\u0442\u0438, \u043F\u0440\u0438 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u043E\u0444\u0438\u043B\u044C
    \u0438\u043C\u0435\u0435\u0442 \u0444\u043E\u0440\u043C\u0443 \u043E\u0432\u0430\u043B\u0430,
    \u043D\u0430\u0438\u0431\u043E\u043B\u044C\u0448\u0438\u0439 \u0438 \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0439
    \u0434\u0438\u0430\u043C\u0435\u0442\u0440\u044B \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043D\u0430\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u0432\u043E \u0432\u0437\u0430\u0438\u043C\u043D\u043E
    \u043F\u0435\u0440\u043F\u0435\u043D\u0434\u0438\u043A\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u044F\u0445;\r\n\u041E\u0433\u0440\u0430\u043D\u043A\u0430
    \u2013 \u043E\u0442\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u0435 \u043E\u0442
    \u043E\u043A\u0440\u0443\u0433\u043B\u043E\u0441\u0442\u0438, \u043F\u0440\u0438
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u043E\u0444\u0438\u043B\u044C \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0443\u044E \u0444\u0438\u0433\u0443\u0440\u0443;\r"
