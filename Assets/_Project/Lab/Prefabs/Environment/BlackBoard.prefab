  m_text: "\u041A\u043E\u043D\u0446\u0435\u0432\u044B\u0435 \u043C\u0435\u0440\u044B,
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u044B\u0435
    \u0434\u043B\u044F \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0431\u043B\u043E\u043A\u0430, \u043F\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0447\u0438\u0449\u0430\u044E\u0442 \u043E\u0442 \u0441\u043C\u0430\u0437\u043A\u0438,
    \u043F\u0440\u043E\u043C\u044B\u0432\u0430\u044E\u0442 \u0447\u0438\u0441\u0442\u044B\u043C
    \u0431\u0435\u0437\u0432\u043E\u0434\u043D\u044B\u043C \u0430\u0432\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u0431\u0435\u043D\u0437\u0438\u043D\u043E\u043C \u0438 \u043F\u0440\u043E\u0442\u0438\u0440\u0430\u044E\u0442
    \u043D\u0430\u0441\u0443\u0445\u043E. \n\u0417\u0430\u0442\u0435\u043C \u043E\u0434\u043D\u0443
    \u043C\u0435\u0440\u0443 \u043D\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u044E\u0442
    \u043D\u0430 \u0434\u0440\u0443\u0433\u0443\u044E \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    \u043D\u0430 1/3 \u0447\u0430\u0441\u0442\u044C \u0440\u0430\u0431\u043E\u0447\u0435\u0439
    \u0434\u043B\u0438\u043D\u044B \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0438, \u043F\u043B\u043E\u0442\u043D\u043E \u043F\u0440\u0438\u0436\u0438\u043C\u0430\u044F
    \u043F\u0430\u043B\u044C\u0446\u0430\u043C\u0438, \u043F\u0440\u043E\u0434\u0432\u0438\u0433\u0430\u044E\u0442
    \u0432\u0434\u043E\u043B\u044C \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043E\u0441\u0438
    \u0434\u043E \u043F\u043B\u043E\u0442\u043D\u043E\u0433\u043E \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u0430
    \u0440\u0430\u0431\u043E\u0447\u0438\u0445 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439.
    \u0415\u0441\u043B\u0438 \u043F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E
    \u043B\u0435\u0433\u043A\u0438\u043C \u0443\u0441\u0438\u043B\u0438\u0435\u043C
    \u043D\u0435 \u0443\u0434\u0430\u0435\u0442\u0441\u044F \u0440\u0430\u0437\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0439 \u0431\u043B\u043E\u043A,
    \u043C\u0435\u0440\u044B \u0441\u0447\u0438\u0442\u0430\u044E\u0442\u0441\u044F
    \u043F\u0440\u0438\u0442\u0435\u0440\u0442\u044B\u043C\u0438. \n"
