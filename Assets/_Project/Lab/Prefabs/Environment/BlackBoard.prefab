  m_text: "\u0412 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445 \u0432\u0441\u0435 \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u0438\u0431\u043E\u0440\u044B \u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
    (\u043F\u043E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0433\u0440\u0430\u0444\u0438\u043A\u0443) \u043F\u043E\u0434\u0432\u0435\u0440\u0433\u0430\u044E\u0442
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0435 (\u0430\u0442\u0442\u0435\u0441\u0442\u0430\u0446\u0438\u0438).\r\n\u0410\u0442\u0442\u0435\u0441\u0442\u0430\u0446\u0438\u044F
    \u0448\u0442\u0430\u043D\u0433\u0435\u043D\u0446\u0438\u0440\u043A\u0443\u043B\u044F
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F \u0432 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0438
    \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u0438 \u0435\u0433\u043E
    \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u0438 \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u043F\u043E\u043F\u0440\u0430\u0432\u043A\u0438. \u0414\u043B\u044F \u0430\u0442\u0442\u0435\u0441\u0442\u0430\u0446\u0438\u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442 \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0435
    \u043C\u0435\u0440\u044B \u0434\u043B\u0438\u043D\u044B. \u0420\u0430\u0437\u043C\u0435\u0440
    \u0431\u043B\u043E\u043A\u0430 \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445
    \u043C\u0435\u0440 \u043D\u0430\u0437\u043D\u0430\u0447\u0430\u0435\u0442\u0441\u044F
    \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0432\u0441\u044E
    \u043E\u0441\u043D\u043E\u0432\u043D\u0443\u044E \u0448\u043A\u0430\u043B\u0443
    \u0438 \u0448\u043A\u0430\u043B\u0443 \u043D\u043E\u043D\u0438\u0443\u0441\u0430.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0434\u043B\u044F \u0448\u0442\u0430\u043D\u0433\u0435\u043D\u0446\u0438\u0440\u043A\u0443\u043B\u044F
    \u0441 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F  
    0\u2013150 \u043C\u043C \u0438 \u0446\u0435\u043D\u043E\u0439 \u0446\u0435\u043B\u0435\u043D\u0438\u044F
    0,1 \u043C\u043C \u043C\u043E\u0436\u043D\u043E \u043D\u0430\u0431\u0440\u0430\u0442\u044C
    \u0431\u043B\u043E\u043A\u0438 \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445
    \u043C\u0435\u0440 \u0442\u0430\u043A\u0438\u0435: 23,1; 58,3; 92,6; 125,8 \u043C\u043C.\r"
