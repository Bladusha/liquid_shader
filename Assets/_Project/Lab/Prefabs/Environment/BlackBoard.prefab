    \u0448\u043A\u0430\u043B\u044B. \u0420\u0430\u0441\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u044E\u0442
    \u043D\u043E\u043D\u0438\u0443\u0441 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C. \u041F\u043E \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439
    \u0434\u043B\u0438\u043D\u0435 \u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439
    \u0448\u043A\u0430\u043B\u044B \"\u0421\", \u0446\u0435\u043D\u0435 \u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043D\u043E\u043D\u0438\u0443\u0441\u0430 \"i\", \u0447\u0438\u0441\u043B\u0443
    \u0434\u0435\u043B\u0435\u043D\u0438\u0439 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439
    \u0448\u043A\u0430\u043B\u044B, \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u043C\u0443
    \u043E\u0434\u043D\u043E\u043C\u0443 \u0434\u0435\u043B\u0435\u043D\u0438\u044E
    \u0448\u043A\u0430\u043B\u044B \u043D\u043E\u043D\u0438\u0443\u0441\u0430 (\u043C\u043E\u0434\u0443\u043B\u044C
    \u043D\u043E\u043D\u0438\u0443\u0441\u0430) \"\u03B3\" \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u044E\u0442
    \u0447\u0438\u0441\u043B\u043E \u0434\u0435\u043B\u0435\u043D\u0438\u0439 \u043D\u043E\u043D\u0438\u0443\u0441\u0430
    \u201Cn\", \u0434\u043B\u0438\u043D\u0443 \u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0448\u043A\u0430\u043B\u044B \u043D\u043E\u043D\u0438\u0443\u0441\u0430 \"b\"
    \u0438 \u043E\u0431\u0449\u0443\u044E \u0434\u043B\u0438\u043D\u0443 \u043D\u043E\u043D\u0438\u0443\u0441\u0430
    \"L\". \u0420\u0430\u0441\u0447\u0435\u0442\u044B \u0432\u0435\u0434\u0443\u0442
    \u043F\u043E \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C:\n<align=\"center\">n
    = C / i\nb = \u03B3 * C - i\nL = n * b"
  m_isRightToLeft: 0
