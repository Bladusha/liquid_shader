--- !u!114 &7645220150551483557
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7645220150551483559}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u0440\u043E\u0432\u0435\u0440\u043A\u0443 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439 \u043E\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043B\u044F\u044E\u0442
    \u043F\u0440\u0438 \u043F\u043E\u043C\u043E\u0449\u0438 \u0441\u0442\u0435\u043A\u043B\u044F\u043D\u043D\u044B\u0445
    \u0446\u0438\u043B\u0438\u043D\u0434\u0440\u043E\u0432. \u041C\u0435\u0442\u043E\u0434
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D \u043D\u0430 \u0442\u043E\u043C, \u0447\u0442\u043E
    \u043C\u0435\u0436\u0434\u0443 \u0437\u0430\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u043D\u044B\u043C
    \u0441\u0442\u0435\u043A\u043B\u044F\u043D\u043D\u044B\u043C \u0446\u0438\u043B\u0438\u043D\u0434\u0440\u043E\u043C
    \u0438 \u0438\u0437\u043D\u043E\u0448\u0435\u043D\u043D\u043E\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C\u044E
    \u043C\u0438\u043A\u0440\u043E\u0432\u0438\u043D\u0442\u0430 (\u0438\u043B\u0438
    \u043F\u044F\u0442\u043A\u0438) \u043E\u0431\u0440\u0430\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432\u043E\u0437\u0434\u0443\u0448\u043D\u044B\u0439 \u043A\u043B\u0438\u043D.
    \u041B\u0443\u0447 \u0441\u0432\u0435\u0442\u0430, \u043F\u0440\u043E\u0445\u043E\u0434\u044F
    \u0447\u0435\u0440\u0435\u0437 \u044D\u0442\u043E\u0442 \u043A\u043B\u0438\u043D,
    \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0440\u0438\u0440\u0443\u0435\u0442
    (\u0440\u0430\u0437\u043B\u0430\u0433\u0430\u0435\u0442\u0441\u044F), \u043D\u0430
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438 \u043C\u0438\u043A\u0440\u043E\u0432\u0438\u043D\u0442\u0430
    \u0438\u043B\u0438 \u043F\u044F\u0442\u043A\u0438 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u044E\u0442\u0441\u044F
    \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u043F\u043E\u043B\u043E\u0441\u044B. \u041F\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0443
    \u044D\u0442\u0438\u0445 \u043F\u043E\u043B\u043E\u0441 \u0441\u0443\u0434\u044F\u0442
    \u043E \u0433\u043E\u0434\u043D\u043E\u0441\u0442\u0438 \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439 \u043C\u0438\u043A\u0440\u043E\u043C\u0435\u0442\u0440\u0430.
    \u041A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u043E\u043D\u043D\u044B\u0445
    \u043F\u043E\u043B\u043E\u0441 (\u0441\u0443\u043C\u043C\u0430\u0440\u043D\u043E\u0435
    \u043D\u0430 \u043C\u0438\u043A\u0440\u043E\u0432\u0438\u043D\u0442\u0435 \u0438
    \u043F\u044F\u0442\u043A\u0435), \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u043D\u043E\u0435
    \u043D\u0430 0,3 \u043C\u043A\u043C, \u0434\u043E\u043B\u0436\u043D\u043E \u0431\u044B\u0442\u044C:
    \u0434\u043B\u044F \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u0432 \u043D\u0443\u043B\u0435\u0432\u043E\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0430 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438
    \u043D\u0435 \u0431\u043E\u043B\u0435\u0435 0,6; \u0434\u043B\u044F \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0430 \u2013 \u043D\u0435 \u0431\u043E\u043B\u0435\u0435
    0,9; \u0434\u043B\u044F \u0432\u0442\u043E\u0440\u043E\u0433\u043E \u043A\u043B\u0430\u0441\u0441\u0430
    \u2013 \u043D\u0435 \u0431\u043E\u043B\u0435\u0435 1,2 \u043C\u043A\u043C."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: dcb83ec56bb0dd348822ab628b70781b, type: 2}
