  m_text: "<b>1.</b> \u041F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0443
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439 \u043C\u0438\u043A\u0440\u043E\u043C\u0435\u0442\u0440\u043E\u0432.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0437\u0430\u043D\u0435\u0441\u0442\u0438
    \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0443\r\n<b>2.</b>\u041F\u0440\u043E\u0432\u0435\u0441\u0442\u0438
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0443 \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u0438
    \u0448\u043A\u0430\u043B\u044B \u043C\u0438\u043A\u0440\u043E\u043C\u0435\u0442\u0440\u0430
    \u043F\u0440\u0438 \u043F\u043E\u043C\u043E\u0449\u0438 \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445
    \u043C\u0435\u0440 \u0434\u043B\u0438\u043D\u044B \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u0447\u043D\u043E
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0435 \u0448\u0442\u0430\u043D\u0433\u0435\u043D\u0446\u0438\u0440\u043A\u0443\u043B\u044F.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0437\u0430\u043D\u0435\u0441\u0442\u0438
    \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0443 \r\n<b>3.</b> \u0414\u0430\u0442\u044C
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435 \u043E \u0433\u043E\u0434\u043D\u043E\u0441\u0442\u0438
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432\n\n<b>\u041F\u0440\u0438\u043C\u0435\u0447\u0430\u043D\u0438\u0435:</b>
    \u041C\u0438\u043A\u0440\u043E\u043C\u0435\u0442\u0440 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u0433\u043E\u0434\u043D\u044B\u043C, \u0435\u0441\u043B\u0438 \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u044C
    \u043D\u0435 \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u0435\u0442 \xB14 \u043C\u043A\u043C,
    \u0438 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u043E\u043D\u043D\u044B\u0445
    \u043F\u043E\u043B\u043E\u0441 (\u0441\u0443\u043C\u043C\u0430\u0440\u043D\u043E\u0435
    \u043D\u0430 \u043C\u0438\u043A\u0440\u043E\u0432\u0438\u043D\u0442\u0435 \u0438
    \u043F\u044F\u0442\u043A\u0435), \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u043D\u043E\u0435
    \u043D\u0430 0,3 \u043C\u043A\u043C - \u043D\u0435 \u0431\u043E\u043B\u0435\u0435
    1,2 \u043C\u043A\u043C."
  m_isRightToLeft: 0
