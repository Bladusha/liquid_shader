  m_text: "\u041F\u0440\u0438 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0438
    \u043C\u0438\u043A\u0440\u043E\u043C\u0435\u0442\u0440\u043E\u043C \u043E\u0442\u0432\u043E\u0434\u044F\u0442
    \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C \u043C\u0438\u043A\u0440\u043E\u0432\u0438\u043D\u0442\u0430,
    \u0432\u0440\u0430\u0449\u0430\u044F \u0431\u0430\u0440\u0430\u0431\u0430\u043D
    \u043D\u0430 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0435
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435. \u041C\u0435\u0436\u0434\u0443
    \u043C\u0438\u043A\u0440\u043E\u0432\u0438\u043D\u0442\u043E\u043C \u0438 \u043F\u044F\u0442\u043A\u043E\u0439
    \u043F\u043E\u043C\u0435\u0449\u0430\u044E\u0442 \u0438\u0437\u043C\u0435\u0440\u044F\u0435\u043C\u0443\u044E
    \u0434\u0435\u0442\u0430\u043B\u044C \u0438 \u043F\u0440\u0438 \u043F\u043E\u043C\u043E\u0449\u0438
    \u0431\u0430\u0440\u0430\u0431\u0430\u043D\u0430 \u0441\u043E\u043A\u0440\u0430\u0449\u0430\u044E\u0442
    \u0437\u0430\u0437\u043E\u0440 \u043C\u0435\u0436\u0434\u0443 \u0438\u0437\u043C\u0435\u0440\u044F\u0435\u043C\u043E\u0439
    \u0434\u0435\u0442\u0430\u043B\u044C\u044E \u0438 \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044F\u043C\u0438
    \u0434\u043E 1\u20132 \u043C\u043C. \u041E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0441\u043E\u043F\u0440\u0438\u043A\u043E\u0441\u043D\u043E\u0432\u0435\u043D\u0438\u0435
    \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439 \u0441
    \u0434\u0435\u0442\u0430\u043B\u044C\u044E \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u044F\u0442
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435\u043C \u0442\u0440\u0435\u0449\u043E\u0442\u043A\u0438
    \u0438 \u0441\u043D\u0438\u043C\u0430\u044E\u0442 \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u0438\u044F
    \u043F\u0440\u0438\u0431\u043E\u0440\u0430."
  m_isRightToLeft: 0
