  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u0440\u0438\u043D\u044F\u0432 \u0440\u0430\u0437\u043C\u0435\u0440
    \u0431\u043B\u043E\u043A\u0430 \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445
    \u043C\u0435\u0440 \u0434\u043B\u0438\u043D\u044B \u0437\u0430 \u044D\u0442\u0430\u043B\u043E\u043D,
    \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u044C \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u0448\u0442\u0430\u043D\u0433\u0435\u043D\u0446\u0438\u0440\u043A\u0443\u043B\u0435\u043C
    \u0440\u0430\u0432\u043D\u0430\r\n<align=\"center\">\u03B4 = X\u03C3 - \u0425,\n<align=\"left\">\u0433\u0434\u0435
    X\u03C3\u2013\u0440\u0430\u0437\u043C\u0435\u0440 \u0431\u043B\u043E\u043A\u0430
    \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445 \u043C\u0435\u0440 \u0434\u043B\u0438\u043D\u044B,
    \u043C\u043C; \r\n\u0425 - \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u0438\u044F
    \u0448\u0442\u0430\u043D\u0433\u0435\u043D\u0446\u0438\u0440\u043A\u0443\u043B\u044F,
    \u043C\u043C.\r\n"
