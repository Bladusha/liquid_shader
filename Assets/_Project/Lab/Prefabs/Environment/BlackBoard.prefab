  m_text: "\u041D\u043E\u043D\u0438\u0443\u0441 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u0441\u043E\u0431\u043E\u0439 \u043B\u0438\u043D\u0435\u0439\u043A\u0443 \u0441\u043E
    \u0448\u043A\u0430\u043B\u043E\u0439, \u043F\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u0442\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u044E\u0442 \u0434\u0440\u043E\u0431\u043D\u044B\u0435
