      m_Calls: []
  m_text: "\u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0431\u043B\u043E\u043A \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445 \u043C\u0435\u0440
    \u0434\u043B\u0438\u043D\u044B \u0440\u0430\u0437\u043C\u0435\u0440\u043E\u043C
    6,375 \u043C\u043C.\r\n\r1,005 + 1,37 + 4,0 = 6,375 \u2013 \u0432\u0435\u0440\u043D\u043E\n1,005\r
    +\t1,07 + 1,30 + 3,0 = 6,375 \u2013 \u043D\u0435\u0432\u0435\u0440\u043D\u043E\n1,005
    + 1,17 + 1,20 + 3,0 = 6,375 \u2013 \u043D\u0435\u0432\u0435\u0440\u043D\u043E\n 
    \t\t\t\t\t\t\n\u0418\u0437 \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0440\u0438\u043C\u0435\u0440\u0430 \u0432\u0438\u0434\u043D\u043E, \u0447\u0442\u043E
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u0439 \u0440\u0430\u0437\u043C\u0435\u0440
    \u0434\u043E\u043B\u0436\u0435\u043D \u0441\u043E\u0431\u0438\u0440\u0430\u0442\u044C\u0441\u044F
    \u0438\u0437 \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445
    \u043C\u0435\u0440 \u0434\u043B\u0438\u043D\u044B.\r\n"
