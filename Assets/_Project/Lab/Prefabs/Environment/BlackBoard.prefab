--- !u!114 &7645220150878456115
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7645220150878456125}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>1.</b> \u041F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u0432\u0438\u0437\u0443\u0430\u043B\u044C\u043D\u044B\u0439
    \u043E\u0441\u043C\u043E\u0442\u0440 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0437\u0430\u043D\u0435\u0441\u0442\u0438
    \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0443\r\n<b>2.</b> \u041D\u0430\u0431\u0440\u0430\u0442\u044C
    \u0431\u043B\u043E\u043A \u043A\u043E\u043D\u0446\u0435\u0432\u044B\u0445 \u043C\u0435\u0440
    \u0434\u043B\u0438\u043D\u044B \u0438 \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u0438\u044F \u0448\u0442\u0430\u043D\u0433\u0435\u043D\u0446\u0438\u0440\u043A\u0443\u043B\u0435\u0439.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0437\u0430\u043D\u0435\u0441\u0442\u0438
    \u0432 \u043F\u0430\u0441\u043F\u043E\u0440\u0442 \r\n<b>3.</b> \u041E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u044C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0437\u0430\u043D\u0435\u0441\u0442\u0438
    \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0443\n<b>4.</b> \u0414\u0430\u0442\u044C
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435 \u043E \u0433\u043E\u0434\u043D\u043E\u0441\u0442\u0438
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432\n\n<b>\u041F\u0440\u0438\u043C\u0435\u0447\u0430\u043D\u0438\u0435:</b>
    \u0428\u0442\u0430\u043D\u0433\u0435\u043D\u0446\u0438\u0440\u043A\u0443\u043B\u044C
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u0433\u043E\u0434\u043D\u044B\u043C,
    \u0435\u0441\u043B\u0438 \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u044C
    \u0432\u043E \u0432\u0441\u0435\u0445 \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u043C\u044B\u0445
    \u0442\u043E\u0447\u043A\u0430\u0445 \u0438\u043C\u0435\u0435\u0442 \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u044B\u0439
    \u0437\u043D\u0430\u043A \u0438 \u043D\u0435 \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u0435\u0442
    \u0446\u0435\u043D\u0443 \u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043D\u043E\u043D\u0438\u0443\u0441\u0430,
    \u0430 \u043C\u0435\u0436\u0434\u0443 \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0433\u0443\u0431\u043A\u0430\u043C\u0438 \u043D\u0435\u0442 \u043F\u0440\u043E\u0441\u0432\u0435\u0442\u0430."
