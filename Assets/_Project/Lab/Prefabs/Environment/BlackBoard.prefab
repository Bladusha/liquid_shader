--- !u!114 &7645220151276372964
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7645220151276372966}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041E\u0442\u0441\u0447\u0435\u0442\u043D\u043E\u0435 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E
    \u043C\u0438\u043A\u0440\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u0441\u043E\u0441\u0442\u043E\u0438\u0442
    \u0438\u0445 \u0434\u0432\u0443\u0445 \u0448\u043A\u0430\u043B. \u041F\u0440\u043E\u0434\u043E\u043B\u044C\u043D\u0430\u044F
    \u0448\u043A\u0430\u043B\u0430 \u0438\u043C\u0435\u0435\u0442 \u0434\u0432\u0430
    \u0440\u044F\u0434\u0430 \u0448\u0442\u0440\u0438\u0445\u043E\u0432 \u0441 \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u043E\u043C
    1 \u043C\u043C, \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0445
    \u043F\u043E \u043E\u0431\u0435 \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u043B\u0438\u043D\u0438\u0438 \u0438 \u0441\u043C\u0435\u0449\u0435\u043D\u043D\u044B\u0445
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0434\u0440\u0443\u0433
    \u0434\u0440\u0443\u0433\u0430 \u043D\u0430 0,5 \u043C\u043C. \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u043E\u0431\u0430 \u0440\u044F\u0434\u0430
    \u0448\u0442\u0440\u0438\u0445\u043E\u0432 \u043E\u0431\u0440\u0430\u0437\u0443\u044E\u0442
    \u043E\u0434\u043D\u0443 \u043F\u0440\u043E\u0434\u043E\u043B\u044C\u043D\u0443\u044E
    \u0448\u043A\u0430\u043B\u0443 \u0441 \u0446\u0435\u043D\u043E\u0439 \u0434\u0435\u043B\u0435\u043D\u0438\u044F
    0,5 \u043C\u043C. \n\u041C\u0438\u043A\u0440\u043E\u0432\u0438\u043D\u0442 \u0441\u0432\u044F\u0437\u0430\u043D
    \u0441 \u0431\u0430\u0440\u0430\u0431\u0430\u043D\u043E\u043C 10, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430 \u043A\u043E\u043D\u0443\u0441\u043D\u043E\u043C \u043A\u043E\u043D\u0446\u0435
    \u0438\u043C\u0435\u0435\u0442 \u043A\u0440\u0443\u0433\u043E\u0432\u0443\u044E
    \u0448\u043A\u0430\u043B\u0443 \u0441 \u0447\u0438\u0441\u043B\u043E\u043C \u0434\u0435\u043B\u0435\u043D\u0438\u0439
    n= 50. \u0423\u0447\u0438\u0442\u044B\u0432\u0430\u044F, \u0447\u0442\u043E \u0448\u0430\u0433
    \u0440\u0435\u0437\u044C\u0431\u044B \u0432\u0438\u043D\u0442\u043E\u0432\u043E\u0439
    \u043F\u0430\u0440\u044B S=0,5 \u043C\u043C, \u0446\u0435\u043D\u0430 \u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043A\u0440\u0443\u0433\u043E\u0432\u043E\u0439 \u0448\u043A\u0430\u043B\u044B
    (\u043D\u043E\u043D\u0438\u0443\u0441\u0430) \u043C\u0438\u043A\u0440\u043E\u043C\u0435\u0442\u0440\u0430
    \"\u0421\" \u0440\u0430\u0432\u043D\u0430 0,01 \u043C\u043C.\n\u0420\u0430\u0437\u043C\u0435\u0440
    \u0438\u0437\u043C\u0435\u0440\u044F\u0435\u043C\u043E\u0439 \u0434\u0435\u0442\u0430\u043B\u0438
    \u0441 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0434\u043E 0,5
    \u043C\u043C \u043E\u0442\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u044E\u0442
    \u043F\u043E \u0448\u043A\u0430\u043B\u0435 \u0441\u0442\u0435\u0431\u043B\u044F,
    \u0443\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u0435\u043C \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0441\u043A\u043E\u0448\u0435\u043D\u043D\u044B\u0439
    \u043A\u0440\u0430\u0439 \u0431\u0430\u0440\u0430\u0431\u0430\u043D\u0430. \u0421\u043E\u0442\u044B\u0435
    \u0434\u043E\u043B\u0438 \u043C\u0438\u043B\u043B\u0438\u043C\u0435\u0442\u0440\u0430
    \u043E\u0442\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u044E\u0442 \u043F\u043E
    \u043A\u0440\u0443\u0433\u043E\u0432\u043E\u0439 \u0448\u043A\u0430\u043B\u0435
    \u0431\u0430\u0440\u0430\u0431\u0430\u043D\u0430, \u0443\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u0435\u043C
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043F\u0440\u043E\u0434\u043E\u043B\u044C\u043D\u044B\u0439 \u0448\u0442\u0440\u0438\u0445
    \u043D\u0430 \u0441\u0442\u0435\u0431\u043B\u0435 \u043C\u0438\u043A\u0440\u043E\u043C\u0435\u0442\u0440\u0430."
