    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>1.</b> \u0418\u0437\u043C\u0435\u0440\u0438\u0442\u044C \u0434\u0435\u0442\u0430\u043B\u044C
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u0441\u0445\u0435\u043C\u0435.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0437\u0430\u043D\u0435\u0441\u0442\u0438
    \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0443\r\n<b>2.</b> \u041E\u043F\u0435\u0440\u0435\u0434\u043B\u0438\u0442\u044C
    \u0432\u0438\u0434\u044B \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u0438
    \u0444\u043E\u0440\u043C\u044B \u0438 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0443
    \u043E\u0442\u043A\u043B\u043E\u043D\u0435\u043D\u0435\u0438\u0439. \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0437\u0430\u043D\u0435\u0441\u0442\u0438 \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0443\r\n<b>3.</b>
    \u0414\u0430\u0442\u044C \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435
    \u043E \u0433\u043E\u0434\u043D\u043E\u0441\u0442\u0438 \u0434\u0435\u0442\u0430\u043B\u0438"
  m_isRightToLeft: 0
